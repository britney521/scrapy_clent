# Django 基础配置
DJANGO_SECRET_KEY=请替换为随机长密钥
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=你的域名.com,服务器IP,127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=https://你的域名.com,http://你的域名.com
DJANGO_SERVE_STATIC=True

# 数据库，默认 sqlite；宝塔也可以先用 sqlite 跑起来
DJANGO_DB_ENGINE=sqlite
DJANGO_DB_NAME=db.sqlite3

# 如果后面改 MySQL，再启用这些配置，并安装 mysqlclient 或 pymysql
# DJANGO_DB_ENGINE=mysql
# DJANGO_DB_NAME=crawler_db
# DJANGO_DB_USER=crawler_user
# DJANGO_DB_PASSWORD=数据库密码
# DJANGO_DB_HOST=127.0.0.1
# DJANGO_DB_PORT=3306

# 任务时间配置
TASK_CLAIM_TIMEOUT_SECONDS=120
TASK_FETCH_COOLDOWN_SECONDS=180

# 外部队列配置
PULL_TASK_BASE_URL=http://8.146.230.26
PULL_TASK_SITE_NAME=GF_TEAM_B_69FFE4
PULL_TASK_TOKEN=G8vmuq9tjoXYerLd6QMaEtLh
PULL_TASK_TIMEOUT=15

# 日志
CRAWLER_LOG_DIR=logs
CRAWLER_LOG_LEVEL=INFO
